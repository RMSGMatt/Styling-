      );

      out = out.replace(
        /On-time fulfillment:\s*\d+(\.\d+)?%/gi,
        `On-time fulfillment: ${onTimePct.toFixed(1)}%`
      );

      out = out.replace(
        /Backorder rate:\s*\d+(\.\d+)?%/gi,
        `Backorder rate: ${backlogRatePct.toFixed(1)}%`
      );

      return out;
    };

    return {
