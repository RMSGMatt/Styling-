import React, { useEffect, useMemo, useState } from "react";

function formatDateTime(value) {
  if (!value) return "—";
  const d = new Date(value);
  if (Number.isNaN(d.getTime())) return String(value);
  return d.toLocaleString();
}

function formatDateOnly(value) {
  if (!value) return "—";
  const d = new Date(value);
  if (Number.isNaN(d.getTime())) return String(value);
  return d.toLocaleDateString();
}

function formatNumber(value, digits = 0) {
  const n = Number(value);
  if (!Number.isFinite(n)) return "—";
  return n.toLocaleString(undefined, {
    minimumFractionDigits: digits,
    maximumFractionDigits: digits,
  });
}

function formatPercent(value, digits = 1) {
  const n = Number(value);
  if (!Number.isFinite(n)) return "—";
  return `${n.toFixed(digits)}%`;
}

function formatCurrency(value) {
  const n = Number(value);
  if (!Number.isFinite(n)) return "—";
  return n.toLocaleString(undefined, {
    style: "currency",
    currency: "USD",
    maximumFractionDigits: 0,
  });
}

function getRunId(run) {
  return (
    run?.run_id ||
    run?.runId ||
    run?.id ||
    run?.timestamp ||
    run?.created_at ||
    null
  );
}

function getRunCreatedAt(run) {
  return (
    run?.created_at ||
    run?.createdAt ||
    run?.timestamp ||
    run?.run_id ||
    null
  );
}

function getRunLabel(run, index = 0) {
  return (
    run?.scenario_name ||
    run?.scenarioName ||
    run?.name ||
    run?.title ||
    `Run ${index + 1}`
  );
}

function getAttachedExecutiveReport(run) {
  return (
    run?.report ||
    run?.executiveReport ||
    run?.executive_report ||
    null
  );
}

function normalizeRuns(simulationHistory) {
  if (!Array.isArray(simulationHistory)) return [];

  return simulationHistory
    .map((run, index) => {
      const runId = getRunId(run);
      const createdAt = getRunCreatedAt(run);

      return {
        raw: run,
        runId,
        createdAt,
        label: getRunLabel(run, index),
        report: getAttachedExecutiveReport(run),
      };
    })
    .filter((run) => run.runId)
    .sort((a, b) => {
      const aTime = new Date(a.createdAt || 0).getTime();
      const bTime = new Date(b.createdAt || 0).getTime();
      return bTime - aTime;
    });
}

function pickArray(...values) {
  for (const value of values) {
    if (Array.isArray(value) && value.length) return value;
  }
  return [];
}

function pickText(...values) {
  for (const value of values) {
    if (typeof value === "string" && value.trim()) return value.trim();
  }
  return "";
}

function pickValue(...values) {
  for (const value of values) {
    if (value !== undefined && value !== null && value !== "") return value;
  }
  return null;
}

function normalizeExecutiveReport(report, selectedRun) {
  if (!report || typeof report !== "object") return null;

  const narrative = report?.narrative || {};
  const inputSource = report?.inputs || {};

  const sections = pickArray(narrative.sections).map((section, index) => ({
    id: section?.id || `section-${index}`,
    title: pickText(section?.title, section?.heading, `Section ${index + 1}`),
    body: pickText(section?.body, section?.text, section?.content),
    bullets: pickArray(section?.bullets, section?.items),
  }));

  return {
    title: pickText(
      narrative.title,
      report.title,
      "Executive Report"
    ),
    subtitle: pickText(
      narrative.summary,
      report.summary,
      report.executive_summary
    ),
    generatedAt: pickValue(
      report.createdAt,
      report.generatedAt,
      report.generated_at,
      report.created_at
    ),
    scenarioName: pickText(
      selectedRun?.raw?.scenario_name,
      selectedRun?.raw?.scenarioName,
      selectedRun?.label
    ),
    dateRangeStart: pickValue(
      inputSource.startDate,
      inputSource.start_date,
      inputSource.sim_start
    ),
    dateRangeEnd: pickValue(
      inputSource.endDate,
      inputSource.end_date,
      inputSource.sim_end
    ),
    sections,
    risks: [],
    actions: [],
  };
}



function computeFrontendBbi(selectedRun) {
  const kpis = selectedRun?.raw?.kpis || {};

  const onTimePct = Number(kpis?.onTimeFulfillment || 0);
  const totalDemand = Number(kpis?.serviceTruth?.totalDemand || 0);
  const peakBacklogUnits = Number(
    kpis?.peakBacklogUnits ??
    kpis?.peakBacklog ??
    0
  );
  const missedServiceDays = Number(
    kpis?.missedServiceDays ??
    kpis?.serviceTruth?.daysWithMissedService ??
    0
  );
  const ttrDays = Number(
    kpis?.ttrDays ??
    kpis?.timeToRecoverDays ??
    0
  );

  const backlogRatePct =
    totalDemand > 0 ? (peakBacklogUnits / totalDemand) * 100 : 0;

  const backlogPenaltyBasis = Math.min(backlogRatePct, 100);
  const missedDaysPenaltyBasis = Math.min((missedServiceDays / 7) * 100, 100);
  const ttrPenaltyBasis = Math.min((ttrDays / 7) * 100, 100);

  const score =
    0.55 * onTimePct +
    0.20 * (100 - backlogPenaltyBasis) +
    0.15 * (100 - missedDaysPenaltyBasis) +
    0.10 * (100 - ttrPenaltyBasis);

  return Math.max(0, Math.min(100, Number(score.toFixed(1))));
}


function normalizeRunKpis(selectedRun) {
  const source = selectedRun?.raw?.kpis || {};

  console.log("RUN KPI SOURCE OF TRUTH", source);

  return {
    serviceLevel: pickValue(
      Number(source.onTimeFulfillment || 0),
      source.onTimeFill,
      
      
    ),
    demandAtRisk: pickValue(
      source.unitsAtRisk,
      source.lateFulfilledUnits,
      source.occurrenceUnfulfilledUnits
    ),
    unfulfilledDemand: pickValue(
      source.peakBacklog,
      source.peakBacklogUnits,
      source.backorderVolume,
      source.endingBacklogExposure
    ),
    ttrDays: pickValue(
      source.ttrDays,
      source.timeToRecoverDays,
      source.timeToRecovery
    ),
    revenueExposure: pickValue(
      source.revenueExposure,
      source.estimatedRevenueExposure
    ),
  };
}

function MetricCard({ label, value }) {
  return (
    <div
      className="rounded-2xl border px-4 py-3"
      style={{
        borderColor: "rgba(94,234,212,0.12)",
        background: "linear-gradient(145deg, rgba(17,24,39,0.96), rgba(30,41,59,0.92))",
        boxShadow: "0 12px 28px rgba(2,6,23,0.28)",
      }}
    >
      <div className="text-[11px] uppercase tracking-[0.18em] text-slate-400 mb-2">
        {label}
      </div>
      <div className="text-[2rem] font-semibold text-white tracking-tight">
        {value}
      </div>
    </div>
  );
}

