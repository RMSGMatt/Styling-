import React, { useEffect, useMemo, useState } from "react";

function formatDateTime(value) {
  if (!value) return "—";
  const d = new Date(value);
  if (Number.isNaN(d.getTime())) return String(value);
  return d.toLocaleString();
}

function formatDateOnly(value) {
  if (!value) return "—";
  const d = new Date(value);
  if (Number.isNaN(d.getTime())) return String(value);
  return d.toLocaleDateString();
}

function formatNumber(value, digits = 0) {
  const n = Number(value);
  if (!Number.isFinite(n)) return "—";
  return n.toLocaleString(undefined, {
    minimumFractionDigits: digits,
    maximumFractionDigits: digits,
  });
}

function formatPercent(value, digits = 1) {
  const n = Number(value);
  if (!Number.isFinite(n)) return "—";
  return `${n.toFixed(digits)}%`;
}

function getRunId(run) {
  return (
    run?.run_id ||
    run?.runId ||
    run?.id ||
    run?.timestamp ||
    run?.created_at ||
    null
  );
}

function getRunCreatedAt(run) {
  return (
    run?.created_at ||
    run?.createdAt ||
    run?.timestamp ||
    run?.run_id ||
    null
  );
}

function getRunLabel(run, index = 0) {
  return (
    run?.scenario_name ||
    run?.scenarioName ||
    run?.name ||
    run?.title ||
    `Run ${index + 1}`
  );
}

function getOutputUrls(run) {
  return (
    run?.outputUrls ||
    run?.output_urls ||
    run?.outputs ||
    {}
  );
}

function getAttachedExecutiveReport(run) {
  return (
    run?.executiveReport ||
    run?.executive_report ||
    run?.report ||
    null
  );
}

function normalizeRuns(simulationHistory) {
  if (!Array.isArray(simulationHistory)) return [];

  return simulationHistory
    .map((run, index) => {
      const runId = getRunId(run);
      const createdAt = getRunCreatedAt(run);
      return {
        raw: run,
        runId,
        createdAt,
        label: getRunLabel(run, index),
        outputs: getOutputUrls(run),
        attachedReport: getAttachedExecutiveReport(run),
      };
    })
    .filter((run) => run.runId)
    .sort((a, b) => {
      const aTime = new Date(a.createdAt || 0).getTime();
      const bTime = new Date(b.createdAt || 0).getTime();
      return bTime - aTime;
    });
}

function pickArray(...values) {
  for (const value of values) {
    if (Array.isArray(value) && value.length) return value;
  }
  return [];
}

function pickText(...values) {
  for (const value of values) {
    if (typeof value === "string" && value.trim()) return value.trim();
  }
  return "";
}

function pickValue(...values) {
  for (const value of values) {
    if (value !== undefined && value !== null && value !== "") return value;
  }
  return null;
}

function normalizeExecutiveReport(report, selectedRun) {
  if (!report || typeof report !== "object") return null;

  const kpisSource =
    report.kpis ||
    report.summary_metrics ||
    report.metrics ||
    {};

  const sections =
    pickArray(
      report.sections,
      report.report_sections
    ).map((section, index) => ({
      id: section?.id || `section-${index}`,
      title: pickText(section?.title, section?.heading, `Section ${index + 1}`),
      body: pickText(section?.body, section?.text, section?.content),
      bullets: pickArray(section?.bullets, section?.items),
    }));

  const risks =
    pickArray(
      report.key_risks,
      report.risks,
      report.top_risks
    );

  const actions =
    pickArray(
      report.recommended_actions,
      report.actions,
      report.next_steps
    );

  return {
    title: pickText(
      report.title,
      report.report_title,
      "Executive Report"
    ),
    subtitle: pickText(
      report.subtitle,
      report.summary,
      report.executive_summary
    ),
    generatedAt: pickValue(
      report.generated_at,
      report.generatedAt,
      report.created_at
    ),
    scenarioName: pickText(
      report.scenario_name,
      report.scenarioName,
      selectedRun?.raw?.scenario_name,
      selectedRun?.raw?.scenarioName,
      selectedRun?.label
    ),
    dateRangeStart: pickValue(
      report.start_date,
      report.date_start,
      report.sim_start
    ),
    dateRangeEnd: pickValue(
      report.end_date,
      report.date_end,
      report.sim_end
    ),
    kpis: {
      serviceLevel: pickValue(
        kpisSource.serviceLevel,
        kpisSource.onTimeFill,
        kpisSource.onTimeFulfillment,
        kpisSource.service_level
      ),
      demandAtRisk: pickValue(
        kpisSource.demandAtRisk,
        kpisSource.unitsAtRisk,
        kpisSource.demand_at_risk,
        kpisSource.units_at_risk
      ),
      unfulfilledDemand: pickValue(
        kpisSource.unfulfilledDemand,
        kpisSource.peakBacklog,
        kpisSource.unfulfilled_demand,
        kpisSource.peak_backlog
      ),
      ttrDays: pickValue(
        kpisSource.ttrDays,
        kpisSource.timeToRecover,
        kpisSource.ttr_days
      ),
      revenueExposure: pickValue(
        kpisSource.revenueExposure,
        kpisSource.estimatedRevenueExposure,
        kpisSource.revenue_exposure
      ),
    },
    sections,
    risks,
    actions,
  };
}

function MetricCard({ label, value }) {
  return (
    <div
      className="rounded-2xl border p-4"
      style={{
        borderColor: "rgba(148,163,184,0.18)",
        background: "rgba(15,23,42,0.55)",
        boxShadow: "0 8px 24px rgba(2,6,23,0.24)",
      }}
    >
      <div className="text-[11px] uppercase tracking-[0.18em] text-slate-400 mb-2">
        {label}
      </div>
      <div className="text-xl font-semibold text-white">
        {value}
      </div>
    </div>
  );
}

export default function Reports(props) {
  const {
    simulationHistory = [],
    token,
    apiBase,
    API_ROOT,
    onReportBuilt,
  } = props || {};

  const resolvedApiBase =
    apiBase ||
    API_ROOT ||
    import.meta.env.VITE_API_BASE ||
    "http://127.0.0.1:5000";

  const runs = useMemo(() => normalizeRuns(simulationHistory), [simulationHistory]);

  const [selectedRunId, setSelectedRunId] = useState("");
  const [localReportsByRun, setLocalReportsByRun] = useState({});
  const [isBuilding, setIsBuilding] = useState(false);
  const [error, setError] = useState("");
  


  useEffect(() => {
    if (!runs.length) {
      setSelectedRunId("");
      return;
    }

    const stillExists = runs.some((run) => run.runId === selectedRunId);
    if (!selectedRunId || !stillExists) {
      setSelectedRunId(runs[0].runId);
    }
  }, [runs, selectedRunId]);

  const selectedRun = useMemo(() => {
    return runs.find((run) => run.runId === selectedRunId) || null;
  }, [runs, selectedRunId]);

  const selectedRunReport = useMemo(() => {

    if (!selectedRun) return null;

    const localReport = localReportsByRun[selectedRun.runId];

    // 🔥 NEW: also check raw run payload for report (App.jsx auto-build)
    const rawReport =
      selectedRun.raw?.report ||
      selectedRun.raw?.executiveReport ||
      selectedRun.raw?.executive_report ||
      null;

    const attachedReport = selectedRun.attachedReport;

    return normalizeExecutiveReport(
      localReport || rawReport || attachedReport,
      selectedRun
    );
  }, [localReportsByRun, selectedRun]);


  
  async function handleBuildExecutiveReport() {
    if (!selectedRun) return;

    setIsBuilding(true);
    setError("");

    try {
      const response = await fetch(
        `${resolvedApiBase}/api/executive-report/build`,
        {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            ...(token ? { Authorization: `Bearer ${token}` } : {}),
          },
          body: JSON.stringify({
            source: "simulation",
            timestamp: selectedRun.raw?.run_id || selectedRun.raw?.id || selectedRun.raw?.timestamp || selectedRun.runId,
            run_id: selectedRun.raw?.run_id || selectedRun.runId,
          }),
        }
      );

      let payload = null;
      try {
        payload = await response.json();
      } catch {
        payload = null;
      }

      if (!response.ok) {
        const message =
          payload?.error ||
          payload?.message ||
          `Executive report build failed (${response.status})`;
        throw new Error(message);
      }

      const builtReport =
        payload?.report ||
        payload?.executiveReport ||
        payload?.executive_report ||
        payload;

      setLocalReportsByRun((prev) => ({
        ...prev,
        [selectedRun.runId]: builtReport,
      }));

      if (typeof onReportBuilt === "function") {
        onReportBuilt(selectedRun.runId, builtReport);
      }
    } catch (err) {
      setError(err?.message || "Failed to build executive report.");
    } finally {
      setIsBuilding(false);
    }
  }

  return (
    <div className="w-full text-white">
      <div className="mb-6">
        <h1 className="text-2xl md:text-3xl font-semibold tracking-tight">
          Executive Reports
        </h1>
        <p className="text-sm text-slate-300 mt-2">
          Select a simulation run and view its executive report. This panel only
          shows the report tied to the selected run.
        </p>
      </div>

      {!runs.length ? (
        <div
          className="rounded-3xl border p-8"
          style={{
            borderColor: "rgba(148,163,184,0.18)",
            background:
              "linear-gradient(135deg, rgba(15,23,42,0.78), rgba(15,23,42,0.58))",
            boxShadow: "0 12px 36px rgba(2,6,23,0.28)",
          }}
        >
          <p className="text-lg font-medium text-white">No simulation runs found</p>
          <p className="text-sm text-slate-300 mt-2">
            Run a simulation first, then return here to build or review its executive report.
          </p>
        </div>
      ) : (
        <div className="grid grid-cols-1 xl:grid-cols-[320px_minmax(0,1fr)] gap-6">
          <aside
            className="rounded-3xl border p-4 md:p-5 h-fit"
            style={{
              borderColor: "rgba(148,163,184,0.18)",
              background:
                "linear-gradient(135deg, rgba(15,23,42,0.78), rgba(15,23,42,0.58))",
              boxShadow: "0 12px 36px rgba(2,6,23,0.28)",
            }}
          >
            <div className="flex items-center justify-between mb-4">
              <div>
                <h2 className="text-sm uppercase tracking-[0.22em] text-slate-400">
                  Simulation Runs
                </h2>
                <p className="text-xs text-slate-500 mt-1">
                  {runs.length} total
                </p>
              </div>
            </div>

            <div className="space-y-3">
              {runs.map((run, index) => {
                const isActive = run.runId === selectedRunId;
                return (
                  <button
                    key={run.runId}
                    type="button"
                    onClick={() => {
                      setSelectedRunId(run.runId);
                      setError("");
                    }}
                    className="w-full text-left rounded-2xl border p-4 transition"
                    style={{
                      borderColor: isActive
                        ? "rgba(34,197,94,0.45)"
                        : "rgba(148,163,184,0.14)",
                      background: isActive
                        ? "rgba(34,197,94,0.12)"
                        : "rgba(15,23,42,0.48)",
                      boxShadow: isActive
                        ? "0 10px 24px rgba(34,197,94,0.10)"
                        : "none",
                    }}
                  >
                    <div className="flex items-start justify-between gap-3">
                      <div>
                        <p className="text-sm font-semibold text-white">
                          {run.label}
                        </p>
                        <p className="text-xs text-slate-400 mt-1">
                          {formatDateTime(run.createdAt)}
                        </p>
                      </div>
                      <div className="text-[10px] uppercase tracking-[0.16em] text-slate-500">
                        #{index + 1}
                      </div>
                    </div>

                    <div className="mt-3 flex flex-wrap gap-2">
                      {run.attachedReport ? (
                        <span className="text-[10px] px-2 py-1 rounded-full bg-emerald-500/15 text-emerald-300 border border-emerald-400/20">
                          Report attached
                        </span>
                      ) : (
                        <span className="text-[10px] px-2 py-1 rounded-full bg-slate-500/15 text-slate-300 border border-slate-400/20">
                          No attached report
                        </span>
                      )}
                    </div>
                  </button>
                );
              })}
            </div>
          </aside>

          <section
            className="rounded-3xl border p-5 md:p-6"
            style={{
              borderColor: "rgba(148,163,184,0.18)",
              background:
                "linear-gradient(135deg, rgba(15,23,42,0.78), rgba(15,23,42,0.58))",
              boxShadow: "0 12px 36px rgba(2,6,23,0.28)",
            }}
          >
            {selectedRun && (
              <>
                <div className="flex flex-col gap-4 md:flex-row md:items-start md:justify-between mb-6">
                  <div>
                    <div className="text-[11px] uppercase tracking-[0.2em] text-emerald-300 mb-2">
                      Selected Run
                    </div>
                    <h2 className="text-2xl font-semibold text-white">
                      {selectedRun.label}
                    </h2>
                    <div className="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm text-slate-300">
                      <div>
                        <span className="text-slate-500">Run ID:</span>{" "}
                        <span className="break-all">{selectedRun.runId}</span>
                      </div>
                      <div>
                        <span className="text-slate-500">Created:</span>{" "}
                        {formatDateTime(selectedRun.createdAt)}
                      </div>
                    </div>
                  </div>

                  <div className="flex flex-wrap gap-3">
                    <button
                      type="button"
                      onClick={handleBuildExecutiveReport}
                      disabled={isBuilding}
                      className="px-4 py-2 rounded-xl text-sm font-semibold border transition"
                      style={{
                        borderColor: "rgba(34,197,94,0.38)",
                        background: isBuilding
                          ? "rgba(34,197,94,0.10)"
                          : "rgba(34,197,94,0.14)",
                        color: "white",
                        opacity: isBuilding ? 0.7 : 1,
                      }}
                    >
                      {isBuilding ? "Building..." : "Build Executive Report"}
                    </button>
                  </div>
                </div>

                {error ? (
                  <div className="mb-5 rounded-2xl border border-red-400/20 bg-red-500/10 px-4 py-3 text-sm text-red-200">
                    {error}
                  </div>
                ) : null}

                {!selectedRunReport ? (
                  <div className="rounded-2xl border border-slate-700/60 bg-slate-900/40 p-6">
                    <p className="text-lg font-medium text-white">
                      No executive report for this run yet
                    </p>
                    <p className="text-sm text-slate-300 mt-2">
                      Build a report for the selected run to populate this panel.
                    </p>
                  </div>
                ) : (
                  <div className="space-y-6">
                    <div className="rounded-2xl border border-slate-700/60 bg-slate-900/40 p-5">
                      <div className="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
                        <div>
                          <p className="text-[11px] uppercase tracking-[0.18em] text-slate-400 mb-2">
                            Executive Report
                          </p>
                          <h3 className="text-2xl font-semibold text-white">
                            {selectedRunReport.title}
                          </h3>
                          {selectedRunReport.subtitle ? (
                            <p className="text-sm text-slate-300 mt-3 max-w-3xl leading-6">
                              {selectedRunReport.subtitle}
                            </p>
                          ) : null}
                        </div>

                        <div className="text-sm text-slate-300 space-y-1">
                          <div>
                            <span className="text-slate-500">Scenario:</span>{" "}
                            {selectedRunReport.scenarioName || "—"}
                          </div>
                          <div>
                            <span className="text-slate-500">Generated:</span>{" "}
                            {formatDateTime(selectedRunReport.generatedAt)}
                          </div>
                          <div>
                            <span className="text-slate-500">Window:</span>{" "}
                            {formatDateOnly(selectedRunReport.dateRangeStart)} -{" "}
                            {formatDateOnly(selectedRunReport.dateRangeEnd)}
                          </div>
                        </div>
                      </div>
                    </div>

                    <div className="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-5 gap-4">
                      <MetricCard
                        label="Service Level"
                        value={formatPercent(selectedRunReport.kpis.serviceLevel)}
                      />
                      <MetricCard
                        label="Demand at Risk"
                        value={formatNumber(selectedRunReport.kpis.demandAtRisk)}
                      />
                      <MetricCard
                        label="Unfulfilled Demand"
                        value={formatNumber(selectedRunReport.kpis.unfulfilledDemand)}
                      />
                      <MetricCard
                        label="TTR"
                        value={
                          selectedRunReport.kpis.ttrDays !== null &&
                          selectedRunReport.kpis.ttrDays !== undefined
                            ? `${formatNumber(selectedRunReport.kpis.ttrDays)} days`
                            : "—"
                        }
                      />
                      <MetricCard
                        label="Revenue Exposure"
                        value={
                          Number.isFinite(Number(selectedRunReport.kpis.revenueExposure))
                            ? Number(selectedRunReport.kpis.revenueExposure).toLocaleString(undefined, {
                                style: "currency",
                                currency: "USD",
                                maximumFractionDigits: 0,
                              })
                            : "—"
                        }
                      />
                    </div>

                    {selectedRunReport.sections?.length ? (
                      <div className="space-y-4">
                        {selectedRunReport.sections.map((section) => (
                          <div
                            key={section.id}
                            className="rounded-2xl border border-slate-700/60 bg-slate-900/40 p-5"
                          >
                            <h4 className="text-lg font-semibold text-white mb-3">
                              {section.title}
                            </h4>

                            {section.body ? (
                              <p className="text-sm text-slate-300 leading-6">
                                {section.body}
                              </p>
                            ) : null}

                            {section.bullets?.length ? (
                              <ul className="mt-4 space-y-2 text-sm text-slate-300 list-disc pl-5">
                                {section.bullets.map((bullet, idx) => (
                                  <li key={`${section.id}-bullet-${idx}`}>{String(bullet)}</li>
                                ))}
                              </ul>
                            ) : null}
                          </div>
                        ))}
                      </div>
                    ) : null}

                    {(selectedRunReport.risks?.length || selectedRunReport.actions?.length) ? (
                      <div className="grid grid-cols-1 xl:grid-cols-2 gap-4">
                        <div className="rounded-2xl border border-slate-700/60 bg-slate-900/40 p-5">
                          <h4 className="text-lg font-semibold text-white mb-3">
                            Key Risks
                          </h4>
                          {selectedRunReport.risks?.length ? (
                            <ul className="space-y-2 text-sm text-slate-300 list-disc pl-5">
                              {selectedRunReport.risks.map((item, idx) => (
                                <li key={`risk-${idx}`}>{String(item)}</li>
                              ))}
                            </ul>
                          ) : (
                            <p className="text-sm text-slate-400">No risks listed.</p>
                          )}
                        </div>

                        <div className="rounded-2xl border border-slate-700/60 bg-slate-900/40 p-5">
                          <h4 className="text-lg font-semibold text-white mb-3">
                            Recommended Actions
                          </h4>
                          {selectedRunReport.actions?.length ? (
                            <ul className="space-y-2 text-sm text-slate-300 list-disc pl-5">
                              {selectedRunReport.actions.map((item, idx) => (
                                <li key={`action-${idx}`}>{String(item)}</li>
                              ))}
                            </ul>
                          ) : (
                            <p className="text-sm text-slate-400">No actions listed.</p>
                          )}
                        </div>
                      </div>
                    ) : null}
                  </div>
                )}
              </>
            )}
          </section>
        </div>
      )}
    </div>
  );
}
