export const KPI_META = {
  serviceLevel: {
    label: "Service Level",
    key: "onTimeFulfillment",
    format: "percent",
    higherIsBetter: true,
    criticalDirection: "down",
  },
  demandAtRisk: {
    label: "Demand at Risk",
    key: "demandAtRisk",
    format: "number",
    higherIsBetter: false,
    criticalDirection: "up",
  },
  peakBacklog: {
    label: "Peak Backlog",
    key: "peakBacklog",
    format: "number",
    higherIsBetter: false,
    criticalDirection: "up",
  },
  ttr: {
    label: "Time to Recover",
    key: "timeToRecoverDays",
    fallbackKeys: ["ttrDays", "TTR"],
    format: "days",
    higherIsBetter: false,
    criticalDirection: "up",
  },
  revenueExposure: {
    label: "Revenue Exposure",
    key: "estimatedRevenueExposure",
    fallbackKeys: ["revenueExposure"],
    format: "currency",
    higherIsBetter: false,
    criticalDirection: "up",
  },
};

function toNumber(value) {
  const n = Number(value);
  return Number.isFinite(n) ? n : 0;
}

function getValue(obj, meta) {
  if (!obj || typeof obj !== "object") return 0;
  if (obj[meta.key] != null) return toNumber(obj[meta.key]);
  for (const fallbackKey of meta.fallbackKeys || []) {
    if (obj[fallbackKey] != null) return toNumber(obj[fallbackKey]);
  }
  return 0;
}

export function formatMetric(value, format) {
  const n = toNumber(value);

  if (format === "percent") return `${n.toFixed(1)}%`;
  if (format === "days") return `${Math.round(n)}d`;
  if (format === "currency") {
    return new Intl.NumberFormat("en-US", {
      style: "currency",
      currency: "USD",
      maximumFractionDigits: 0,
    }).format(n);
  }
  return new Intl.NumberFormat("en-US", {
    maximumFractionDigits: 0,
  }).format(n);
}

function buildDelta(current, baseline, higherIsBetter) {
  const rawDelta = current - baseline;
  const absDelta = Math.abs(rawDelta);

  let direction = "flat";
  if (rawDelta > 0) direction = "up";
  if (rawDelta < 0) direction = "down";

  const isWorse =
    direction !== "flat" &&
    ((higherIsBetter && rawDelta < 0) || (!higherIsBetter && rawDelta > 0));

  return {
    current,
    baseline,
    rawDelta,
    absDelta,
    direction,
    isWorse,
    isBetter: direction !== "flat" && !isWorse,
  };
}

function severityFromDelta(metricId, deltaInfo) {
  const magnitude = deltaInfo.absDelta;

  if (!deltaInfo.isWorse) {
    return {
      level: "positive",
      icon: "✅",
      tone: "emerald",
      label: "Improved",
    };
  }

  switch (metricId) {
    case "serviceLevel":
      if (magnitude >= 20) return { level: "critical", icon: "🔴", tone: "red", label: "Critical" };
      if (magnitude >= 8) return { level: "warning", icon: "🟠", tone: "amber", label: "Watch" };
      return { level: "mild", icon: "🟡", tone: "yellow", label: "Shift" };

    case "demandAtRisk":
    case "peakBacklog":
      if (magnitude >= 500) return { level: "critical", icon: "🔴", tone: "red", label: "Critical" };
      if (magnitude >= 150) return { level: "warning", icon: "🟠", tone: "amber", label: "Watch" };
      return { level: "mild", icon: "🟡", tone: "yellow", label: "Shift" };

    case "ttr":
      if (magnitude >= 5) return { level: "critical", icon: "🔴", tone: "red", label: "Critical" };
      if (magnitude >= 2) return { level: "warning", icon: "🟠", tone: "amber", label: "Watch" };
      return { level: "mild", icon: "🟡", tone: "yellow", label: "Shift" };

    case "revenueExposure":
      if (magnitude >= 250000) return { level: "critical", icon: "🔴", tone: "red", label: "Critical" };
      if (magnitude >= 50000) return { level: "warning", icon: "🟠", tone: "amber", label: "Watch" };
      return { level: "mild", icon: "🟡", tone: "yellow", label: "Shift" };

    default:
      return { level: "warning", icon: "🟠", tone: "amber", label: "Watch" };
  }
}

function deltaArrow(deltaInfo) {
  if (deltaInfo.direction === "flat") return "•";
  return deltaInfo.direction === "up" ? "↑" : "↓";
}

export function buildBaselineComparison(currentKpis = {}, baselineKpis = null) {
  const hasBaseline = !!baselineKpis;

  const cards = Object.entries(KPI_META).map(([metricId, meta]) => {
    const current = getValue(currentKpis, meta);
    const baseline = hasBaseline ? getValue(baselineKpis, meta) : 0;
    const deltaInfo = buildDelta(current, baseline, meta.higherIsBetter);
    const severity = hasBaseline
      ? severityFromDelta(metricId, deltaInfo)
      : { level: "neutral", icon: "ℹ️", tone: "slate", label: "No baseline" };

    return {
      metricId,
      label: meta.label,
      format: meta.format,
      current,
      baseline,
      delta: deltaInfo.rawDelta,
      deltaAbs: deltaInfo.absDelta,
      deltaDirection: deltaInfo.direction,
      deltaArrow: deltaArrow(deltaInfo),
      isWorse: deltaInfo.isWorse,
      isBetter: deltaInfo.isBetter,
      severity,
      currentDisplay: formatMetric(current, meta.format),
      baselineDisplay: hasBaseline ? formatMetric(baseline, meta.format) : "—",
      deltaDisplay:
        meta.format === "percent"
          ? `${deltaInfo.rawDelta > 0 ? "+" : ""}${deltaInfo.rawDelta.toFixed(1)} pts`
          : `${deltaInfo.rawDelta > 0 ? "+" : ""}${formatMetric(deltaInfo.rawDelta, meta.format)}`,
    };
  });

  return {
    hasBaseline,
    cards,
    worstCard:
      cards.find((c) => c.severity.level === "critical" && c.isWorse) ||
      cards.find((c) => c.severity.level === "warning" && c.isWorse) ||
      cards.find((c) => c.severity.level === "mild" && c.isWorse) ||
      null,
  };
}

function topMaterialRisk(materialRiskData = []) {
  if (!Array.isArray(materialRiskData) || materialRiskData.length === 0) return null;

  const ranked = [...materialRiskData].sort((a, b) => {
    const aScore =
      toNumber(a.unitsAtRisk) +
      toNumber(a.atRiskDemand) +
      toNumber(a.revenueExposure) / 1000;
    const bScore =
      toNumber(b.unitsAtRisk) +
      toNumber(b.atRiskDemand) +
      toNumber(b.revenueExposure) / 1000;
    return bScore - aScore;
  });

  return ranked[0] || null;
}

function actionFromRisk(materialRiskData = [], currentKpis = {}, baselineKpis = null) {
  const topRisk = topMaterialRisk(materialRiskData);
  const atRisk = toNumber(currentKpis?.demandAtRisk);
  const currentTtr =
    toNumber(currentKpis?.timeToRecoverDays) || toNumber(currentKpis?.ttrDays);
  const baselineTtr =
    toNumber(baselineKpis?.timeToRecoverDays) || toNumber(baselineKpis?.ttrDays);

  const daysRecoverable =
    baselineTtr > 0 && currentTtr > baselineTtr
      ? Math.max(1, Math.round(currentTtr - baselineTtr))
      : Math.max(1, Math.round(currentTtr * 0.25));

  const facility =
    topRisk?.facility ||
    topRisk?.location ||
    topRisk?.node ||
    topRisk?.site ||
    "the constrained facility";

  const component =
    topRisk?.material ||
    topRisk?.component ||
    topRisk?.sku ||
    "the constrained component";

  return `Expedite supply at ${facility} to protect ${Math.round(
    atRisk
  )} units of at-risk demand and reduce recovery time by ~${daysRecoverable} days. Focus on ${component} first.`;
}

export function buildDecisionNarrative({
  currentKpis = {},
  baselineKpis = null,
  materialRiskData = [],
} = {}) {
  const serviceLevel = toNumber(currentKpis?.onTimeFulfillment);
  const atRisk = toNumber(currentKpis?.demandAtRisk);
  const peakBacklog = toNumber(currentKpis?.peakBacklog);
  const ttr =
    toNumber(currentKpis?.timeToRecoverDays) || toNumber(currentKpis?.ttrDays);
  const revenueExposure =
    toNumber(currentKpis?.estimatedRevenueExposure) ||
    toNumber(currentKpis?.revenueExposure);

  const baselineService = toNumber(baselineKpis?.onTimeFulfillment);
  const serviceDrop = baselineKpis ? baselineService - serviceLevel : 0;

  const topRisk = topMaterialRisk(materialRiskData);
  const driver = (() => {
  if (!Array.isArray(materialRiskData) || materialRiskData.length === 0) {
    return "upstream supply constraints";
  }

  const top = materialRiskData[0] || {};

  const material =
    top.material || top.component || top.sku || "key component";

  const facility =
    top.facility || top.location || top.node || "critical facility";

  const supplier =
    top.supplier || top.source || "";

  if (supplier) {
    return `${supplier} disruption impacting ${material} at ${facility}`;
  }

  return `${material} constraint at ${facility}`;
})();

  const facility =
    topRisk?.facility ||
    topRisk?.location ||
    topRisk?.node ||
    topRisk?.site ||
    "the constrained node";

  const opening = baselineKpis
    ? `Service degraded to ${serviceLevel.toFixed(
        1
      )}% from a ${baselineService.toFixed(
        1
      )}% baseline`
    : `Service is tracking at ${serviceLevel.toFixed(1)}%`;

  const impact = `driven by ${driver}, creating ${Math.round(
    atRisk
  )} units of at-risk demand, a peak backlog of ${Math.round(
    peakBacklog
  )}, and extending recovery to ${Math.round(ttr)} days`;

  const businessRisk =
    revenueExposure > 0
      ? `with approximately ${formatMetric(
          revenueExposure,
          "currency"
        )} in revenue exposure`
      : `with customer service risk escalating quickly`;

  const urgency =
    atRisk > 0 || peakBacklog > 0
      ? `Without intervention, customer service risk escalates at ${facility}.`
      : `The network remains stable, but this constraint should be monitored closely.`;

  const action = actionFromRisk(materialRiskData, currentKpis, baselineKpis);

  return {
    headline:
      serviceLevel < 70
        ? "Service failure risk — immediate action required"
        : serviceLevel < 90
        ? "Service degradation detected"
        : "Service stable with emerging risk",

    summary: `${Math.round(serviceLevel)}% service level vs baseline${
      baselineKpis ? ` (${baselineService.toFixed(1)}%)` : ""
    } driven by ${driver}. ${Math.round(
      atRisk
    )} units at risk, backlog peaking at ${Math.round(
      peakBacklog
    )}, and recovery extending to ${Math.round(
      ttr
    )} days. ${atRisk > 0 ? "Customer service impact is already occurring." : ""}`,

    action,
  };
}

